  "version": "7.3.20.2026",
  "description": "갤러리, 글, 댓글, 유저까지, 보고 싶지 않은 콘텐츠를 차단합니다",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "디시갤 차단기 – 설정"
  },
  "permissions": [
    "storage",
    "activeTab",
    "declarativeNetRequest",
    "contextMenus"
  ],
  "host_permissions": [
    "*://gall.dcinside.com/*",
    "*://www.dcinside.com/*",
    "*://search.dcinside.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": []
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
  },
  "minimum_chrome_version": "105",
